<Window x:Class="JSON___02___Produkte.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JSON___02___Produkte"
        mc:Ignorable="d"
        Title="Produktinfomrationen" Height="370" Width="570">
    <Grid>
        <Label Content="Kategorien:" HorizontalAlignment="Left" Margin="20,20,0,0" VerticalAlignment="Top" Height="30" Width="250"/>
        <Label Content="Produktname:" HorizontalAlignment="Left" Margin="300,20,0,0" VerticalAlignment="Top" Height="30" Width="250"/>
        <ComboBox x:Name="comboBoxKategorie" HorizontalAlignment="Left" Margin="20,50,0,0" VerticalAlignment="Top" Width="250" Height="30" SelectionChanged="KategorieWahl"/>
        <TextBox x:Name="textBoxProduktname" HorizontalAlignment="Left" Margin="300,50,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="250" Height="30"/>
        <Label Content="Produkte:" HorizontalAlignment="Left" Margin="20,100,0,0" VerticalAlignment="Top" Width="250"/>
        <ListBox x:Name="listBoxProdukte" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="20,130,0,0" Width="250" Height="200" HorizontalAlignment="Left" VerticalAlignment="Top" SelectionChanged="Produktwahl"/>
        <Label Content="Preis:" HorizontalAlignment="Left" Margin="300,100,0,0" VerticalAlignment="Top" Width="250"/>
        <TextBox x:Name="textBoxPreis" HorizontalAlignment="Left" Margin="300,130,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="250" TextChanged="TextBox_TextChanged"/>

    </Grid>
</Window>
